{
  "entry": "specs/index.spec.md",
  "adapters": [],
  "setup": "sh scripts/spec-env.sh",
  "teardown": "sh scripts/spec-teardown.sh",
  "defaultTimeoutMsec": 120000,
  "reporters": [
    {
      "builtin": "html",
      "outFile": ".specdown/report"
    },
    {
      "builtin": "json",
      "outFile": ".specdown/report.json"
    }
  ],
  "toc": [
    "specs/index.spec.md",
    {
      "group": "Features",
      "docs": [
        "specs/auth.spec.md",
        "specs/space.spec.md",
        "specs/ssh.spec.md"
      ]
    },
    {
      "group": "Reference",
      "docs": [
        "specs/config-resolution.spec.md"
      ]
    },
    {
      "group": "Validation",
      "docs": [
        "specs/testing.spec.md"
      ]
    }
  ]
}
